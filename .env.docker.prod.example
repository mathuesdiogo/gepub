# Copie para .env.docker.prod e troque TODOS os segredos antes de produção.

# Domínio público da aplicação (usado pelo Caddy)
APP_DOMAIN=app.gepub.com.br
ACME_EMAIL=suporte@gepub.com.br

DJANGO_SECRET_KEY=troque-por-uma-chave-longa-e-unica
DJANGO_CPF_HASH_KEY=troque-por-uma-chave-forte
DJANGO_CPF_ENCRYPTION_KEY=troque-por-uma-chave-forte

DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=app.gepub.com.br

GEPUB_PUBLIC_ROOT_DOMAIN=gepub.com.br
GEPUB_APP_HOSTS=app.gepub.com.br
GEPUB_APP_CANONICAL_HOST=app.gepub.com.br

DJANGO_DB_ENGINE=postgresql
DJANGO_DB_NAME=gepub
DJANGO_DB_USER=gepub
DJANGO_DB_PASSWORD=troque-esta-senha
DJANGO_DB_HOST=db
DJANGO_DB_PORT=5432
DJANGO_DB_CONN_MAX_AGE=120

DJANGO_CACHE_BACKEND=redis
DJANGO_REDIS_URL=redis://redis:6379/1

CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_EAGER_PROPAGATES=true
CELERY_LOGLEVEL=INFO
CELERY_WORKER_CONCURRENCY=2

CHANNEL_LAYER_IN_MEMORY=false
CHANNEL_REDIS_URL=redis://redis:6379/2

MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_MASTER_KEY=troque-esta-chave-meili
MEILISEARCH_INDEX_PREFIX=gepub

# Segurança HTTPS em produção
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SESSION_COOKIE_SECURE=true
DJANGO_CSRF_COOKIE_SECURE=true
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=true
DJANGO_SECURE_HSTS_PRELOAD=true
DJANGO_CSRF_TRUSTED_ORIGINS=https://app.gepub.com.br

DRF_PAGE_SIZE=25
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7
JWT_ROTATE_REFRESH_TOKENS=true
JWT_BLACKLIST_AFTER_ROTATION=false
JWT_UPDATE_LAST_LOGIN=false

REDIS_HOST=redis
REDIS_PORT=6379
WAIT_FOR_REDIS=1
COLLECTSTATIC_ON_START=1

POSTGRES_DB=gepub
POSTGRES_USER=gepub
POSTGRES_PASSWORD=troque-esta-senha
