DJANGO_SECRET_KEY=troque-por-uma-chave-longa-e-aleatoria
DJANGO_CPF_HASH_KEY=troque-por-uma-chave-dedicada-para-hash-cpf
DJANGO_CPF_ENCRYPTION_KEY=troque-por-uma-chave-dedicada-para-criptografia-cpf
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,.gepub.com.br
GEPUB_PUBLIC_ROOT_DOMAIN=gepub.com.br
GEPUB_APP_HOSTS=app.gepub.com.br,127.0.0.1,localhost
# GEPUB_APP_CANONICAL_HOST=app.gepub.com.br
# GEPUB_RESERVED_SUBDOMAINS=app,www,admin,api,static,media

# Banco (dev default = sqlite). Para PostgreSQL:
# DJANGO_DB_ENGINE=postgresql
# DJANGO_DB_NAME=gepub
# DJANGO_DB_USER=gepub
# DJANGO_DB_PASSWORD=troque-esta-senha
# DJANGO_DB_HOST=127.0.0.1
# DJANGO_DB_PORT=5432

# Cache (produção recomendada)
# DJANGO_CACHE_BACKEND=redis
# DJANGO_REDIS_URL=redis://127.0.0.1:6379/1
# DJANGO_CACHE_BACKEND=memcached
# DJANGO_MEMCACHED_LOCATION=127.0.0.1:11211
# DJANGO_ALLOW_LOCMEM_IN_PRODUCTION=false

# Fila assíncrona (Celery)
# CELERY_BROKER_URL=redis://127.0.0.1:6379/1
# CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
# CELERY_TASK_ALWAYS_EAGER=false
# CELERY_TASK_EAGER_PROPAGATES=true

# API (DRF + JWT)
# DRF_PAGE_SIZE=25
# JWT_ACCESS_TOKEN_MINUTES=15
# JWT_REFRESH_TOKEN_DAYS=7
# JWT_ROTATE_REFRESH_TOKENS=true
# JWT_BLACKLIST_AFTER_ROTATION=false
# JWT_UPDATE_LAST_LOGIN=false
# JWT_SIGNING_KEY=

# Realtime (Channels)
# CHANNEL_LAYER_IN_MEMORY=false
# CHANNEL_REDIS_URL=redis://127.0.0.1:6379/2

# Busca (Meilisearch)
# MEILISEARCH_URL=http://127.0.0.1:7700
# MEILISEARCH_MASTER_KEY=
# MEILISEARCH_INDEX_PREFIX=gepub

# Segurança HTTP/HTTPS (produção)
# DJANGO_SECURE_SSL_REDIRECT=true
# DJANGO_SESSION_COOKIE_SECURE=true
# DJANGO_CSRF_COOKIE_SECURE=true
# DJANGO_SECURE_HSTS_SECONDS=31536000
# DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=true
# DJANGO_SECURE_HSTS_PRELOAD=true
# DJANGO_SECURE_CROSS_ORIGIN_OPENER_POLICY=same-origin
# DJANGO_SECURE_CROSS_ORIGIN_RESOURCE_POLICY=same-origin
# DJANGO_CSRF_TRUSTED_ORIGINS=https://app.gepub.com.br,https://*.gepub.com.br

# Login / anti brute-force
# DJANGO_LOGIN_MAX_ATTEMPTS_PER_CODE=5
# DJANGO_LOGIN_MAX_ATTEMPTS_PER_IP=25
# DJANGO_LOGIN_LOCK_MINUTES=10

# Upload
# DJANGO_DATA_UPLOAD_MAX_MEMORY_SIZE=10485760
# DJANGO_FILE_UPLOAD_MAX_MEMORY_SIZE=5242880
# GEPUB_PROFILE_MAX_UPLOAD_BYTES=2097152
# PAINEIS_MAX_UPLOAD_MB=50
# CONVERSOR_MAX_UPLOAD_MB=80
# COMUNICACAO_API_MAX_JSON_BODY_BYTES=262144

# Geolocalizacao / Maps
# GEPUB_GEOCODE_PROVIDER=osm
# GOOGLE_GEOCODING_API_KEY=
# GEPUB_GEOCODE_TIMEOUT_SECONDS=6
# GEPUB_GEOCODE_USER_AGENT=GEPUB/1.0 (suporte@gepub.com.br)

# Docker local:
# - use o arquivo .env.docker (base: .env.docker.example)
# - compose sobe postgres/redis/meilisearch + web/worker/beat
